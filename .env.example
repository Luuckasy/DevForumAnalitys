DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# AI provider: openai | gemini | groq. Gemini is the default (free tier).
AI_PROVIDER=gemini

# Only the key for the selected provider is required.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

CHECK_INTERVAL_MINUTES=10
DEVFORUM_BASE_URL=https://devforum.roblox.com

# Updates (cat 45) and Resources (cat 17) only.
MONITORED_ENDPOINTS=/c/updates/45.json,/c/resources/17.json

# Empty = accept everything from the configured endpoints.
KEYWORDS=
IGNORE_KEYWORDS=

# Per-category minimum likes. Format: CATEGORY_ID=MIN_LIKES, comma-separated.
# Resources (17) needs 15+ likes; Updates (45) passes regardless.
MIN_LIKES_BY_CATEGORY=17=15
# Fallback for categories not listed above. 0 = no filter.
MIN_LIKES=0

MAX_TOPICS_PER_CHECK=30
DATABASE_PATH=./data/devforum_bot.sqlite3
